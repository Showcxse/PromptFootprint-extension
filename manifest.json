{
    "manifest_version": 3,
    "name": "PromptFootprint",
    "version": "0.1.0",
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "src/background/index.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["https://chatgpt.com/* https://claude.ai/*"],
            "js": ["src/content/index.js"]
        }
    ],
    "permissions": ["storage"]
}